# Django Settings
SECRET_KEY=your-secret-key-here
FIELDNODE_API_KEY=your-fieldnode-api-key-here
DEBUG=False

# Allowed Hosts and CORS
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Next.js frontend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api
NEXT_PUBLIC_FIELDNODE_API_KEY=your-fieldnode-api-key-here

# Database Settings
USE_SQLITE=False
DB_NAME=fieldnode_db
DB_USER=root
DB_PASSWORD=root_password
DB_HOST=localhost
DB_PORT=3306
