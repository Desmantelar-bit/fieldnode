# FieldNode Environment Configuration

# Django Core
SECRET_KEY=django-insecure-local-dev-key
DEBUG=True
FIELDNODE_API_KEY=fieldnode-demo-2024

# Database (docker-compose sets DB_HOST=db, local dev uses localhost)
DB_NAME=fieldnode
DB_USER=root
DB_PASSWORD=fieldnode2024
DB_HOST=db
DB_PORT=3306

# Notes:
# - For Docker: use "db" as DB_HOST (service name in docker-compose.yml)
# - For local dev: use "localhost" as DB_HOST and ensure MySQL is running locally
